# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
API_KEY="internal-api-key"

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSIONS=1536
CHAT_MODEL="gpt-4o"

# ─── RAG ──────────────────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RAG_TOP_K=5
